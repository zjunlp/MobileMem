# ============================================================================
# LLM API (OpenAI-compatible, used for text generation)
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
# Fallback model used only when a call does not pass an explicit model.
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_CN=deepseek-chat
# Text model selected per persona language and passed explicitly by every stage
# (this is what get_text_llm_model returns). Defaults to gpt-5.1.
TEXT_LLM_MODEL=gpt-5.1
TEXT_LLM_MODEL_CN=gpt-5.1
OPENAI_MAX_TOKENS=16384
OPENAI_TEMPERATURE=0.5
OPENAI_TIMEOUT=180
# Retry policy for transient API errors
RETRY_TIMES=30
WAIT_TIME_LOWER=10
WAIT_TIME_UPPER=30

# ============================================================================
# Image generation - provider switch
# ============================================================================
# "openrouter" (default; Gemini image model via the chat endpoint) or "dmx".
IMAGE_PROVIDER=openrouter

# --- OpenRouter (default image provider; OpenAI-style API key) ---
# Falls back to OPENAI_API_KEY if left unset.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# Optional proxy for image calls (some image models are region-restricted).
# Leave empty to disable explicit proxying.
IMAGE_HTTP_PROXY=
# Downscale large input images to this longest side (px) before edit calls.
IMAGE_MAX_INPUT_SIDE=1024
# Retry count for transient image API errors (separate from RETRY_TIMES).
IMAGE_RETRY_TIMES=30

# --- DMX (alternative image provider; OpenAI /images/generations style) ---
DMX_API_KEY=your_image_api_key_here
DMX_BASE_URL=https://www.dmxapi.cn/v1
DMX_GENERATION_URL=https://www.dmxapi.cn/v1/images/generations
DMX_EDIT_URL=https://www.dmxapi.cn/v1/images/edits
DMX_CHINESE_GENERATION_MODEL=doubao-seedream-4-5-251128
DMX_CHINESE_EDIT_MODEL=doubao-seedream-4-5-251128
DMX_CHINESE_EDIT_PROMPT_MAX=1000

# ============================================================================
# LLM call logging (optional)
# ============================================================================
LLM_CALL_LOGS_ENABLED=true
# LLM_CALL_LOGS_DIR=output/llm_call_logs
